# =============================================================================
# pwa-oura — infrastruktuurin ymptäristömuuttujat
# Kopioi tämä .env.infra-tiedostoksi ja täytä arvot.
# ÄLÄ lisää .env.infra:a versionhallintaan (.gitignore).
# =============================================================================

# Google Cloud
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=europe-north1

# Firebase (yleensä sama kuin GCP_PROJECT_ID)
FIREBASE_PROJECT_ID=your-firebase-project-id

# Oura API OAuth 2.0
# Rekisteröi osoitteessa: https://cloud.ouraring.com/oauth/applications
OURA_CLIENT_ID=your-oura-client-id
OURA_CLIENT_SECRET=your-oura-client-secret

# MQTT broker
# Esim. HiveMQ Cloud: mqtt://your-cluster.hivemq.cloud:1883
# Tai Cloud IoT Core / Mosquitto / Aiven
MQTT_BROKER_URL=mqtt://your-broker-host:1883
MQTT_TOPIC_PREFIX=oura
